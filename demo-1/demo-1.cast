[0.000, "o", "\u001b[0;34m\u001b[1m══════════════════════════════════════════════════\u001b[0m\r\n\u001b[0;34m\u001b[1m  Demo 1 Complete\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;34m\u001b[1m══════════════════════════════════════════════════\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[0;90mLink Shelf built by 3 subagents (2 parallel + 1 dependent).\u001b[0m\r\n\u001b[0;90mParallel execution where possible, but parent manages all dependencies.\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;90mNo peer messaging, no shared task list, no auto-unblocking.\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[0;32m\u001b[1mNext:\u001b[0m Demo 2 adds search using Agent Teams — same parallelism\u001b[0m\r\n"]
[0.000, "o", "\u001b[0m      but with coordination primitives: shared task list, peer\u001b[0m\r\n\u001b[0m      messaging, and automatic dependency resolution.\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[1m\u001b[7m%\u001b[27m\u001b[1m\u001b[0m                                                                                                                                                  \r \r"]
