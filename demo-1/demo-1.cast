[0.009, "o", "\r\n\u001b[0;34m\u001b[1m══════════════════════════════════════════════════\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;34m\u001b[1m  Demo 1: Subagents Build Link Shelf\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;34m\u001b[1m══════════════════════════════════════════════════\u001b[0m\r\n\r\n\u001b[0;90mThis demo shows Pattern 1: Subagents with parallel execution.\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;90mThe parent orchestrator identifies independent tasks and runs them\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;90msimultaneously, then runs dependent tasks after their prereqs complete.\u001b[0m\r\n\r\n  \u001b[0;32mPHASE 1 (parallel)\u001b[0m\r\n"]
[0.000, "o", "    \u001b[0;34mSubagent 1\u001b[0m → Data Layer    (db.js)          ┐\r\n"]
[0.000, "o", "    \u001b[0;33mSubagent 2\u001b[0m → Business Logic (validation.js) ├─ run simultaneously\r\n"]
[0.000, "o", "                                                ┘\r\n"]
[0.000, "o", "  \u001b[0;33mPHASE 2 (after both complete)\u001b[0m\r\n"]
[0.000, "o", "    \u001b[0;35mSubagent 3\u001b[0m → API Routes     (server.js)     ← reads both reports\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0;90mEach subagent writes a report file. The parent manages dependencies manually.\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;90mNo shared task list, no peer messaging — that's what Agent Teams add (Demo 2).\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.001, "o", "\u001b[0;32m▸\u001b[0m \u001b[1mLaunching Claude Code with subagent prompt...\u001b[0m\r\n\r\n"]
