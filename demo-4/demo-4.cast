[0.003, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[9A\u001b[38;2;78;186;101mвҸә\r\u001b[1B\u001b[38;2;153;153;153m  вҺҝ В \u001b[39mAdded\u001b[1C\u001b[1m15\u001b[1C\u001b[22mlines\r\u001b[1B \u001b[1C   \u001b[38;2;248;248;242m\u001b[2m 17 \u001b[22m \u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m Use descriptive HTTP status codes (400 for validation, 404 for not found, 500 for server)\r\u001b[1B\u001b[39m     \u001b[38;2;248;248;242m\u001b[2m 18 \u001b[22m \u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m Keep functions small and focused вҖ” one function per operation\u001b[39m                 \r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 19 \u001b[22m \u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m No console.log in production code вҖ” use only in test files\r\u001b[1B\u001b[39m     \u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 20 +\u001b[38;2;248;248;242m                                                                                                                                  \u001b[49m\u001b[39m       \r\u001b[1B   \u001b[2C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 21 +\u001b[38;2;253;151;31m## Migrations (learned 2026-03-25)\u001b[38;2;248;248;242m                                                                                          "]
[0.000, "o", "      \r\u001b[1B\u001b[49m\u001b[39m     \u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 22 +\u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m NEVER rely solely on CREATE TABLE IF NOT EXISTS to add new columns вҖ” it's a no-op when the table already exists with data\u001b[38;2;248;248;242m       \u001b[49m\u001b[39m       \r\u001b[2C\u001b[1B   \u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 23 +\u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m ALWAYS use ALTER TABLE ADD COLUMN for adding columns to existing tables\u001b[38;2;248;248;242m                                                         \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 24 +\u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m Wrap ALTER TABLE in try/catch ignoring \"duplicate column\" errors to make migrations idempotent (safe to run multiple times)\u001b[38;2;248;248;242m     \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 25 +\u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m Test migrations against both fresh databases AND existing databases with data\u001b[38;2;248;248;242m                                                   \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;"]
[0.000, "o", "2;40;0m 26 +\u001b[38;2;248;248;242m                                                                                                                                  \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 27 +\u001b[38;2;253;151;31m## Route Ordering (learned 2026-03-25)\u001b[38;2;248;248;242m                                                                                            \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 28 +\u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m Named sub-routes like \u001b[38;2;236;53;51m`/api/links/favorites`\u001b[38;2;255;255;255m MUST be defined BEFORE parameterized routes like \u001b[38;2;236;53;51m`/api/links/:id`\u001b[38;2;255;255;255m, otherwise Expres\u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m    +\u001b[38;2;255;255;255ms matches \"favorites\" as an :id parameter\u001b[38;2;248;248;242m                                                                                         \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 29 +\u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m Same applies to \u001b[38;2;236;53;51m`/a"]
[0.000, "o", "pi/links/search`\u001b[38;2;255;255;255m вҖ” all literal paths before wildcard params\u001b[38;2;248;248;242m                                                  \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 30 +\u001b[38;2;248;248;242m                                                                                                                                  \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 31 +\u001b[38;2;253;151;31m## Hook-Caught Mistakes (learned 2026-03-25)\u001b[38;2;248;248;242m                                                                                      \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 32 +\u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m The grep console.log hook catches accidental debug logging вҖ” always check before marking a task done\u001b[38;2;248;248;242m                            \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 33 +\u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m If adding new features, ensure the test file covers both positive AND negative cases (valid toggle, invalid id, non-ex"]
[0.000, "o", "istent lin\u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m    +\u001b[38;2;255;255;255mk)\u001b[38;2;248;248;242m                                                                                                                                \u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 34 +\u001b[38;2;119;119;119m-\u001b[38;2;255;255;255m Quality gate hooks are only as good as their exclusion patterns вҖ” exclude node_modules/ from grep checks to avoid false positive\u001b[49m\u001b[39m\r\r\n\u001b[5C\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m    +\u001b[38;2;255;255;255ms\u001b[38;2;248;248;242m                                                                                                                                 \u001b[49m\u001b[39m\r\r\n\r\r\n\u001b[38;2;215;119;87mВ·\u001b[1CMoonwalkingвҖҰ\u001b[1C\u001b[38;2;153;153;153m(1m\u001b[1C39s\u001b[1CВ·\u001b[1CвҶ‘\u001b[1C2.8k\u001b[1Ctokens)\u001b[39m\r\r\n\u001b[38;2;153;153;153m \u001b[1CвҺҝ\u001b[1CВ Tip:\u001b[1CUse\u001b[1C/btw\u001b[1Cto\u001b[1Cask\u001b[1Ca\u001b[1Cquick\u001b[1Cside\u001b[1Cquestion\u001b[1Cwithout\u001b[1Cinterrupting\u001b[1CClaude's\u001b[1Ccurrent\u001b[1Cwork\u001b[39m\r\r\n\r\r\n\u001b[38;2;136;136;136mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"]
