[0.000, "o", "\u001b[1G"]
[0.000, "o", "\u001b[0K"]
[0.292, "o", "Link Shelf API listening on http://localhost:3456\r\n"]
[0.199, "o", "\r\nLink Shelf ‚Äî Test Suite\r\n\r\nValidation:\r\n"]
[0.000, "o", "  ‚úì validateLink rejects missing fields\r\n"]
[0.002, "o", "  ‚úì validateLink rejects invalid url\r\n"]
[0.000, "o", "  ‚úì validateLink sanitizes HTML\r\n"]
[0.000, "o", "  ‚úì validateLink passes valid input\r\n"]
[0.001, "o", "  ‚úì validatePartialLink rejects empty input\r\n"]
[0.000, "o", "  ‚úì validatePartialLink accepts partial fields\r\n"]
[0.002, "o", "  ‚úì validateId coerces string to number\r\n"]
[0.000, "o", "  ‚úì validateId rejects non-positive\r\n"]
[0.001, "o", "  ‚úì sanitizeString strips HTML\r\n"]
[0.000, "o", "  ‚úì isValidUrl rejects non-http urls\r\n"]
[0.000, "o", "  ‚úì parseTags handles array input\r\n"]
[0.000, "o", "  ‚úì parseTags handles comma string input\r\n\r\nData Layer:\r\n"]
[0.002, "o", "  ‚úì createLink inserts and returns row\r\n"]
[0.000, "o", "  ‚úì getLinkById returns undefined for missing\r\n"]
[0.001, "o", "  ‚úì updateLink returns null for missing id\r\n"]
[0.000, "o", "  ‚úì deleteLink returns deleted false for missing\r\n\r\nAPI ‚Äî CRUD lifecycle:\r\n"]
[0.044, "o", "  ‚úì POST /api/links ‚Äî create\r\n"]
[0.005, "o", "  ‚úì GET /api/links ‚Äî list all\r\n"]
[0.004, "o", "  ‚úì GET /api/links/:id ‚Äî get one\r\n"]
[0.004, "o", "  ‚úì PUT /api/links/:id ‚Äî update\r\n"]
[0.003, "o", "  ‚úì DELETE /api/links/:id ‚Äî delete\r\n"]
[0.003, "o", "  ‚úì GET /api/links/:id ‚Äî 404 after delete\r\n\r\nAPI ‚Äî Error handling:\r\n"]
[0.002, "o", "  ‚úì POST /api/links ‚Äî 400 on missing fields\r\n"]
[0.002, "o", "  ‚úì POST /api/links ‚Äî 400 on invalid URL\r\n"]
[0.002, "o", "  ‚úì PUT /api/links/:id ‚Äî 400 on empty body\r\n"]
[0.005, "o", "  ‚úì GET /api/links/:id ‚Äî 400 on invalid id\r\n"]
[0.001, "o", "  ‚úì DELETE /api/links/999 ‚Äî 404\r\n"]
[0.002, "o", "  ‚úì POST /api/links ‚Äî HTML sanitization via API\r\n"]
[0.003, "o", "  ‚úì POST /api/links ‚Äî 409 duplicate URL\r\n"]
[0.002, "o", "  ‚úì POST /api/links ‚Äî tags as array\r\n\r\nSearch API:\r\n"]
[0.004, "o", "  ‚úì Search returns matching results\r\n"]
[0.002, "o", "  ‚úì Search with no matches returns empty\r\n"]
[0.002, "o", "  ‚úì Search is case-insensitive\r\n"]
[0.000, "o", "  ‚úì Search validates input ‚Äî missing q param returns 400\r\n"]
[0.001, "o", "  ‚úì Search validates input ‚Äî empty q param returns 400\r\n\r\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\r\nResults: 35 passed, 0 failed, 35 total\r\n"]
