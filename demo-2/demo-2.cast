[0.000, "o", "\u001b[0;32m\u001b[1m  Demo 2: Agent Teams Add Search to Link Shelf\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;32m\u001b[1m‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[0;90mThis demo shows Pattern 2: Agent Teams (true parallel with coordination).\u001b[0m\r\n\u001b[0;90mStarting from the Link Shelf app built in Demo 1, we add search using\u001b[0m\r\n\u001b[0;90m3 teammates with a shared task list, peer messaging, and auto-unblocking.\u001b[0m\r\n\r\n"]
[0.000, "o", "  \u001b[0;32mTeam Lead\u001b[0m ‚Üí creates task list, spawns teammates, synthesizes results\r\n"]
